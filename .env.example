# Canonical site URL used for metadata, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://abhinay-portfolio-five.vercel.app

# Resend API key for the contact form (https://resend.com/api-keys).
# Without it the form falls back to opening the visitor's mail client.
RESEND_API_KEY=

# Verified sender for contact-form emails. Defaults to Resend's onboarding
# sender, which only delivers to your own account's email.
CONTACT_FROM_EMAIL=
